# target_name:
#   project_id: moz-fx-data-shared-dev # or personal sandbox
#   dataset_prefix: dev_user_{{ git.branch }}_{{ git.commit}}_ # optional prefix; git.branch, git.commit, and artifact.project_id are available

shared_dev:
  project_id: moz-fx-data-shared-dev
  dataset: {{ user.name }}_{{ git.branch }}
  artifact_prefix: {{ artifact.project_id }}__{{ artifact.dataset }}__

dev:
  project_id: your-sandbox-project  # TODO: specify your personal sandbox project
  dataset_prefix: dev_{{ git.branch }}__{{ artifact.project_id }}__
